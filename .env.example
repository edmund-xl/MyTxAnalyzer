APP_NAME=On-chain RCA Workbench API
ENVIRONMENT=development
POSTGRES_PASSWORD=REPLACE_ME_POSTGRES_PASSWORD
DATABASE_URL=postgresql+psycopg://rca:REPLACE_ME_POSTGRES_PASSWORD@postgres:5432/rca_workbench
REDIS_URL=redis://redis:6379/0
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minio
MINIO_ROOT_PASSWORD=REPLACE_ME_MINIO_ROOT_PASSWORD
MINIO_SECRET_KEY=REPLACE_ME_MINIO_ROOT_PASSWORD
MINIO_BUCKET=rca-artifacts
OBJECT_STORE_MODE=s3
LOCAL_ARTIFACT_ROOT=./.artifacts
TEMPORAL_ADDRESS=temporal:7233
WORKFLOW_MODE=temporal
TXANALYZER_ROOT=/opt/txanalyzer
TXANALYZER_PYTHON=python
TXANALYZER_TIMEOUT_SECONDS=120
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:3100","http://127.0.0.1:3100"]

# Public RPCs are non-secret fallbacks for local smoke tests. Replace with
# a dedicated provider for heavy analysis, archive calls, or trace/debug calls.
ETH_RPC_URL=https://ethereum-rpc.publicnode.com
ETHERSCAN_API_KEY=
BSC_RPC_URL=https://bsc-dataseed1.binance.org/
BSCSCAN_API_KEY=
ARBITRUM_RPC_URL=https://arbitrum-one-rpc.publicnode.com
ARBISCAN_API_KEY=
BASE_RPC_URL=https://base-rpc.publicnode.com
BASESCAN_API_KEY=
UNICHAIN_RPC_URL=https://unichain-rpc.publicnode.com
UNISCAN_API_KEY=
TAIKO_RPC_URL=https://taiko-rpc.publicnode.com
TAIKOSCAN_API_KEY=
MEGAETH_RPC_URL=https://mainnet.megaeth.com/rpc
MEGAETH_EXPLORER_API_KEY=
SUI_RPC_URL=https://fullnode.mainnet.sui.io:443
LLM_API_KEY=
NEXT_PUBLIC_API_BASE_URL=http://localhost:8100/api
