{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CreateCaseRequest",
  "type": "object",
  "required": ["network_key", "seed_type", "seed_value"],
  "properties": {
    "title": {"type": "string"},
    "network_key": {"type": "string", "minLength": 1},
    "seed_type": {"type": "string", "enum": ["transaction", "address", "contract", "alert"]},
    "seed_value": {"type": "string", "minLength": 1},
    "time_window_hours": {"type": "integer", "minimum": 1, "maximum": 168, "default": 6},
    "depth": {"type": "string", "enum": ["quick", "full", "full_replay"], "default": "quick"},
    "modules": {"type": "array", "items": {"type": "string"}},
    "language": {"type": "string", "enum": ["zh-CN", "en-US"], "default": "zh-CN"}
  }
}
